# Dota 2 AI Coach — copy this to .env and fill in your values
# The app loads .env automatically on startup (no need to use 'set' or 'export')

# === LLM Provider ===
# Pick one: openai | anthropic | ollama
COACH_LLM_PROVIDER=openai

# === OpenAI (default) ===
OPENAI_API_KEY=sk-...your-key-here...
# OPENAI_MODEL=gpt-4o-mini

# === Anthropic (alternative) ===
# ANTHROPIC_API_KEY=sk-ant-...your-key-here...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# === Ollama (free, local — no API key needed) ===
# Install from https://ollama.com, then: ollama pull llama3.2
# COACH_LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
